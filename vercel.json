{
  "images": {
    "sizes": [256, 384, 640, 750, 828, 1080, 1200, 1920, 2048, 3840],
    "minimumCacheTTL": 60,
    "formats": ["image/webp", "image/avif"]
  },
  "crons": [
    {
      "path": "/api/adoptions/reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/lost-pets/reminders",
      "schedule": "0 10 * * 0"
    },
    {
      "path": "/api/pets/stuck-reminders",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/notifications/cleanup",
      "schedule": "0 3 * * *"
    }
  ]
}
